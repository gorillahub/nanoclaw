#!/usr/bin/env sh
# Format only the staged .ts/.tsx files (not the whole codebase).
# Previously this ran `prettier --write "src/**/*.ts"` which failed the
# commit whenever any unrelated file in src/ had drifted formatting or
# was unwriteable (e.g. ownership mismatch on a host checkout). That
# pushed edits toward --no-verify or required chown dances. Scoping to
# staged files means unrelated drift doesn't block targeted commits.

STAGED=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(ts|tsx)$' || true)

if [ -z "$STAGED" ]; then
  exit 0
fi

echo "$STAGED" | xargs npx prettier --write
echo "$STAGED" | xargs git add
